<?xml version="1.0"?>
<robot name="my_rover">

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.5 0.4 0.25"/>
      </geometry>
      <material name="chassis_color">
        <color rgba="0.2 0.2 0.2 1.0"/> </material>
    </visual>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <link name="front_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <material name="wheel_color">
        <color rgba="0.0 0.0 0.0 1.0"/> </material>
    </visual>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.2 0.225 -0.05" rpy="-1.5708 0 0"/> <axis xyz="0 0 1"/> </joint>

  <link name="bno055">
    <visual>
      <geometry>
        <box size="0.03 0.02 0.01"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="bno055"/>
    <origin xyz="0.05 0.0 0.1" rpy="0 0 0"/>
  </joint>

</robot>